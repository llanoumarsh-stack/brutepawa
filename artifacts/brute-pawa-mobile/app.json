{
  "expo": {
    "name": "Brute Pawa",
    "slug": "brute-pawa-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "brutepawa",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1877F2"
    },

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.brutepawa.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Brute Pawa utilise la caméra pour les appels vidéo et les photos de profil.",
        "NSMicrophoneUsageDescription": "Brute Pawa utilise le micro pour les appels audio et vidéo.",
        "NSPhotoLibraryUsageDescription": "Brute Pawa accède à vos photos pour les partager dans les messages.",
        "NSLocationWhenInUseUsageDescription": "Brute Pawa utilise votre position pour partager votre localisation."
      }
    },

    "android": {
      "package": "com.brutepawa.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1877F2"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "brutepawa.app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },

    "web": {
      "favicon": "./assets/images/icon.png"
    },

    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Brute Pawa accède à vos photos pour les partager.",
          "cameraPermission": "Brute Pawa utilise la caméra pour les photos et appels vidéo."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Brute Pawa utilise votre position pour la partager."
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "eas": {
        "projectId": "brute-pawa-mobile"
      }
    }
  }
}
